#!/usr/bin/env bash

# Get the WiFi signal icon for the currently connected network
CONNECTED=$(nmcli -t -f type,state,names,device dev | grep "^wifi:connected" | awk -F: '{print $3}')

if [ -z "$CONNECTED" ]; then
    echo "ůį§®"  # No connection
    exit 0
fi

# Get signal strength of connected network
SIGNAL=$(nmcli -t -f type,signal,device dev | grep "^wifi" | awk -F: '{print $2}' | head -1)

if [ -z "$SIGNAL" ]; then
    echo "ůį§®"
    exit 0
fi

# Display appropriate icon based on signal strength
if [ "$SIGNAL" -ge 75 ]; then
    echo "ůį§ü"
elif [ "$SIGNAL" -ge 50 ]; then
    echo "ůį§Ę"
elif [ "$SIGNAL" -ge 25 ]; then
    echo "ůį§•"
else
    echo "ůį§®"
fi
