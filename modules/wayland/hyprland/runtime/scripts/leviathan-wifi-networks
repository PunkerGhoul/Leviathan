#!/usr/bin/env bash

# Show available WiFi networks using rofi
# Can be called with 'display' to just show networks or 'menu' to show selector

MODE="${1:-display}"

# Get connected SSID
CONNECTED_SSID=$(nmcli -t -f active,ssid dev wifi | grep '^yes:' | cut -d: -f2)

# Get available networks with signal strength
get_networks() {
    nmcli device wifi list --rescan yes 2>/dev/null | tail -n +2 | awk -v connected="$CONNECTED_SSID" '
    {
        if (NF > 0) {
            ssid = $1
            signal = $(NF-2)
            security = $NF
            
            # Create signal bars
            if (signal >= 75) bars = "󰤟"
            else if (signal >= 50) bars = "󰤢"
            else if (signal >= 25) bars = "󰤥"
            else bars = "󰤨"
            
            # Mark connected network
            if (ssid == connected) {
                printf "✓ %s %d%%  %s\n", bars, signal, ssid
            } else {
                printf "  %s %d%%  %s\n", bars, signal, ssid
            }
        }
    }' | sort -t'%' -k1 -rn | awk '!seen[$3]++' | head -30
}

case "$MODE" in
    display)
        get_networks
        ;;
    menu)
        SELECTED=$(get_networks | sed 's/^[✓ ]* //' | rofi -dmenu -p "WiFi Networks" -theme-str 'window { width: 400px; }')
        if [ -n "$SELECTED" ]; then
            SSID=$(echo "$SELECTED" | awk '{print $NF}')
            # Try to connect (will prompt for password if needed)
            nmcli device wifi connect "$SSID" 2>/dev/null || \
            nmcli --ask device wifi connect "$SSID"
        fi
        ;;
    *)
        get_networks
        ;;
esac
